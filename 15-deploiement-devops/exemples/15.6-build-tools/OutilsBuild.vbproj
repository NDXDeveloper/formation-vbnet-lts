<!-- =========================================================================
  Section 15.6 : Outils de build .NET 10 — élagage des paquets NuGet
  Description : Console VB.NET (net10.0). L'ÉLAGAGE DES PAQUETS (activé par
                défaut en .NET 10) retire du graphe les paquets déjà fournis par
                le framework. Ici, une référence directe à System.Text.Json —
                fournie par le runtime — devient redondante : NuGet émet
                l'avertissement NU1510 (« supprimez la référence »). À ne pas
                confondre avec le trimming IL (cf. 15.1).
  Fichier source : 06-outils-build-net10.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>OutilsBuild</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

  <ItemGroup>
    <!-- Référence DIRECTE redondante : le runtime .NET 10 fournit déjà
         System.Text.Json → l'élagage la neutralise et NuGet émet NU1510.
         (Le code ci-dessous l'utilise ; c'est la version du RUNTIME qui sert.) -->
    <PackageReference Include="System.Text.Json" Version="8.0.5" />
  </ItemGroup>

</Project>
