<!-- =========================================================================
  Section 15.4 : Conteneurisation — service de fond VB
  Description : Faute de modèle de projet « Worker » en VB, on câble À LA MAIN un
                service de fond : console + Generic Host + BackgroundService
                (cf. module 4.8). Conteneurisé comme n'importe quelle console.
                Les propriétés Container* permettent à `dotnet publish
                /t:PublishContainer` de produire une image OCI — y compris en
                ARCHIVE (tarball) SANS démon Docker. .NET 10 couvre désormais les
                consoles sans EnableSdkContainerSupport.
  Fichier source : 04-docker.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Travailleur</RootNamespace>
    <AssemblyName>Travailleur</AssemblyName>
    <TargetFramework>net10.0</TargetFramework>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>

    <!-- Configuration de l'image conteneur (publication conteneur du SDK). -->
    <ContainerRepository>travailleur-vb</ContainerRepository>
    <ContainerImageTags>1.0.0;latest</ContainerImageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.0" />
  </ItemGroup>

</Project>
