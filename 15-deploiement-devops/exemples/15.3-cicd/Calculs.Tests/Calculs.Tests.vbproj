<!-- =========================================================================
  Section 15.3 : CI/CD — tests exécutés par le pipeline
  Description : Projet de test xUnit (VB) que la phase « test » du pipeline
                lance via `dotnet test`. Démontre la colonne vertébrale
                agnostique : restore → build → test → publish, identique à C#.
  Fichier source : 03-cicd.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Calculs.Tests</RootNamespace>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Calculs\Calculs.vbproj" />
  </ItemGroup>

</Project>
