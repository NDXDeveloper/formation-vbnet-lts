<!-- =========================================================================
  Section 18.4 : Migration vers C# — filet de tests (le garde-fou sémantique)
  Description : Tests xUnit (VB) référençant la bibliothèque C# migrée. Ils encodent
                l'équivalence ATTENDUE (le « ^ » de VB == Math.Pow en C#) et épinglent
                la DIVERGENCE d'une conversion littérale (== XOR). C'est ce filet de
                tests — la même discipline qu'au module 11 et au module 17 — qui
                rattrape les pièges sémantiques que le compilateur laisse passer.
  Fichier source : 04-migrer-vers-csharp.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>CalculsTests</RootNamespace>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\CalculsCsharp\CalculsCsharp.csproj" />
  </ItemGroup>

</Project>
