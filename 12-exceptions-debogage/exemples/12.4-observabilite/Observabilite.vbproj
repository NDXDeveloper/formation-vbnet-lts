<!-- =========================================================================
  Section 12.4 : Observabilité (notions : métriques et traces)
  Description : Console VB.NET (.NET 10) démontrant les PRIMITIVES natives de
                la BCL qu'OpenTelemetry collecte : System.Diagnostics.Metrics
                (Meter + Counter, lus ici via un MeterListener) et
                System.Diagnostics.Activity (ActivitySource + Activity + tags,
                observés via un ActivityListener). Ces primitives s'émettent
                pleinement depuis VB.NET. Les health checks et le câblage
                OpenTelemetry relèvent de l'hôte web (documentés au README).
  Fichier source : 04-observabilite.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Observabilite</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

</Project>
