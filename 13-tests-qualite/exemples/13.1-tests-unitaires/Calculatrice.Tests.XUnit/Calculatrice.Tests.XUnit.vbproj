<!-- =========================================================================
  Section 13.1 : Tests unitaires — xUnit (VB.NET)
  Description : Projet de test xUnit. <Fact>, <Theory>/<InlineData>, test
                asynchrone (Async Function … As Task) et test d'exception
                (Assert.Throws). Aucun attribut de classe requis en xUnit.
  Fichier source : 01-tests-unitaires.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Calculatrice.Tests.XUnit</RootNamespace>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Calculatrice\Calculatrice.vbproj" />
  </ItemGroup>

</Project>
