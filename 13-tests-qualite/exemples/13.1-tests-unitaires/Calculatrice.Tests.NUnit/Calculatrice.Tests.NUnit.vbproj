<!-- =========================================================================
  Section 13.1 : Tests unitaires — NUnit (VB.NET)
  Description : Projet de test NUnit. Met en évidence LE piège VB n°1 : « Is »
                est un mot-clé VB, on doit donc échapper la classe de contraintes
                en [Is].EqualTo(...). Tests simples, <TestCase> paramétrés, async
                et exception.
  Fichier source : 01-tests-unitaires.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Calculatrice.Tests.NUnit</RootNamespace>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="NUnit" Version="4.2.2" />
    <PackageReference Include="NUnit3TestAdapter" Version="4.6.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Calculatrice\Calculatrice.vbproj" />
  </ItemGroup>

</Project>
