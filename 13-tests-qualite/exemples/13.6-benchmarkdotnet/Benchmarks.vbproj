<!-- =========================================================================
  Section 13.6 : BenchmarkDotNet (notions)
  Description : Console VB.NET (.NET 10) de micro-benchmark : compare la
                concaténation par &= et StringBuilder. BenchmarkDotNet gère ce
                que la mesure naïve néglige (chauffe JIT, GC, processus isolés,
                statistiques, allocations) et s'utilise sans réserve en VB.NET.
                ⚠️ À exécuter en RELEASE (BenchmarkDotNet refuse Debug).
  Fichier source : 06-benchmarkdotnet.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Benchmarks</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" Version="0.14.0" />
  </ItemGroup>

</Project>
