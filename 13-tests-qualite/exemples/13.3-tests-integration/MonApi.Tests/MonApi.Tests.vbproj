<!-- =========================================================================
  Section 13.3 : Tests d'intégration — projet de test (VB.NET)
  Description : Tests xUnit d'intégration : WebApplicationFactory(Of Program)
                exécute toute la Web API en mémoire (vraies requêtes HTTP), et
                EF Core est testé contre une VRAIE base SQLite (in-memory),
                jamais le fournisseur InMemory trompeur. Pas de Docker requis ;
                Testcontainers (qui l'exige) est documenté au README.
  Fichier source : 03-tests-integration.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>MonApi.Tests</RootNamespace>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <!-- Nécessaire pour héberger l'application web (WebApplicationFactory). -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="10.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MonApi\MonApi.vbproj" />
  </ItemGroup>

</Project>
