<!-- =========================================================================
  Section 13.2 : Mocking — Moq (VB.NET)
  Description : Tests xUnit utilisant Moq : construction d'une doublure
                (Mock(Of IRepositoryCommandes)), configuration de réponses
                (Setup/Returns), vérification d'appels (Verify/Times),
                correspondances d'arguments (It.IsAny), et exception simulée.
  Fichier source : 02-mocking-tdd.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Commandes.Tests.Moq</RootNamespace>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
    <PackageReference Include="Moq" Version="4.20.72" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Commandes\Commandes.vbproj" />
  </ItemGroup>

</Project>
