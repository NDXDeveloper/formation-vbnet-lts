<!-- =========================================================================
  Section 13.2 : Mocking et TDD — code testable (SUT)
  Description : Bibliothèque conçue POUR la testabilité : ServiceCommandes
                dépend d'une ABSTRACTION (IRepositoryCommandes) injectée par
                constructeur — donc remplaçable par une doublure. C'est la
                condition du mocking : on ne remplace que ce qui est une
                interface (ou un membre Overridable).
  Fichier source : 02-mocking-tdd.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Commandes</RootNamespace>
    <AssemblyName>Commandes</AssemblyName>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

</Project>
