<!-- =========================================================================
  Section 13.5 : Couverture de code — code mesuré (SUT)
  Description : Bibliothèque VB.NET contenant DEUX méthodes : Doubler (couverte
                par un test) et Tripler (DÉLIBÉRÉMENT non testée). La couverture
                sera donc < 100 % — ce qui illustre le vrai intérêt de la
                métrique : révéler ce qui N'EST PAS testé.
  Fichier source : 05-couverture-tests-ia.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Couverture</RootNamespace>
    <AssemblyName>Couverture</AssemblyName>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

</Project>
