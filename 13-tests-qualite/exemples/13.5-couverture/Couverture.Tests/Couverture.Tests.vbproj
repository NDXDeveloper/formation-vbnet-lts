<!-- =========================================================================
  Section 13.5 : Couverture de code — projet de test + Coverlet
  Description : Projet de test xUnit instrumenté par Coverlet
                (coverlet.collector). La collecte « XPlat Code Coverage » de
                dotnet test produit un rapport Cobertura (XML), utilisable tel
                quel en VB.NET. Seul Doubler est testé : la couverture sera
                partielle.
  Fichier source : 05-couverture-tests-ia.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Couverture.Tests</RootNamespace>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
    <PackageReference Include="coverlet.collector" Version="6.0.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Couverture\Couverture.vbproj" />
  </ItemGroup>

</Project>
