<!-- =========================================================================
  Section 5.2 : Windows Forms sur .NET 10 (modernisation)
  Description : Projet Windows Forms VB.NET (.NET 10) a cadre applicatif
                (MyType=WindowsForms), structure comme le cree Visual Studio.
  Fichier source : 02-winforms-net10.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>WinFormsNet10</RootNamespace>
    <MyType>WindowsForms</MyType>
    <StartupObject>WinFormsNet10.My.MyApplication</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <Import Include="System.Data" />
    <Import Include="System.Drawing" />
    <Import Include="System.Windows.Forms" />
  </ItemGroup>

</Project>
