<!-- =========================================================================
  Section 5.3 : Controles fondamentaux
  Description : Projet Windows Forms VB.NET (.NET 10) a cadre applicatif
                (MyType=WindowsForms), structure comme le cree Visual Studio.
  Fichier source : 03-controles-fondamentaux.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace>ControlesFondamentaux</RootNamespace>
    <MyType>WindowsForms</MyType>
    <StartupObject>ControlesFondamentaux.My.MyApplication</StartupObject>
  </PropertyGroup>

  <ItemGroup>
    <Import Include="System.Data" />
    <Import Include="System.Drawing" />
    <Import Include="System.Windows.Forms" />
  </ItemGroup>

</Project>
