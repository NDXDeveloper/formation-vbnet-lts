<!-- =========================================================================
  Section 11.6 : Moderniser (async, LINQ, injection de dépendances, testabilité)
  Description : Console VB.NET (.NET 10) illustrant la modernisation idiomatique
                d'un code converti : boucle impérative → LINQ (même résultat),
                E/S → Async/Await sans blocage, et injection de dépendances
                (Microsoft.Extensions.DependencyInjection) remplaçant les « New »
                en dur et les dépendances statiques (DateTime.Now) par une
                couture testable (horloge injectée). (EF Core : voir module 7.)
  Fichier source : 06-moderniser.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Moderniser</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.0" />
  </ItemGroup>

</Project>
