<!-- =========================================================================
  Section 8.5 : gRPC et GraphQL — client VB.NET
  Description : Console VB qui CONSOMME les trois voies depuis VB pur :
                (1) gRPC natif via la bibliothèque cliente C# référencée
                    (ProjectReference) — VB ne génère pas de proto, il consomme
                    des types .NET ordinaires ;
                (2) le même service gRPC en REST/JSON (JSON transcoding), avec
                    un simple HttpClient (comme § 8.1) ;
                (3) GraphQL en HTTP brut (POST query/variables + JsonDocument).
  Fichier source : 05-grpc-graphql.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>ClientVb</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.Net.Client" Version="2.*" />
  </ItemGroup>

  <ItemGroup>
    <!-- La brique gRPC est isolée en C# ; VB la référence et la consomme. -->
    <ProjectReference Include="..\Catalogue.Grpc\Catalogue.Grpc.csproj" />
  </ItemGroup>

</Project>
