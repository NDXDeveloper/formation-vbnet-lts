<!-- =========================================================================
  Section 8.2 : Exposer une Web API ASP.NET Core (par contrôleurs)
  Description : Web API VB.NET complète (.NET 10). Aucun modèle de projet VB
                n'existe : on part d'un console VB basculé sur le SDK Web
                (Microsoft.NET.Sdk.Web). Couvre contrôleurs/ControllerBase,
                routage par attributs, liaison + validation DataAnnotations,
                injection de dépendances, middleware personnalisé, OpenAPI 3.1
                + Scalar, Problem Details (RFC 9457), versioning (Asp.Versioning),
                rate limiting intégré et authentification JWT Bearer.
  Fichier source : 02-web-api-controllers.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>WebApiControllers</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- Le générateur de commentaires XML -> OpenAPI est C#-only ; il n'émet
         rien ici, d'où ce warning attendu que l'on neutralise. -->
    <NoWarn>$(NoWarn);1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.0" />
    <PackageReference Include="Scalar.AspNetCore" Version="2.16.3" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.0" />
    <PackageReference Include="Asp.Versioning.Mvc" Version="8.1.1" />
    <PackageReference Include="Asp.Versioning.Mvc.ApiExplorer" Version="8.1.1" />
  </ItemGroup>

</Project>
