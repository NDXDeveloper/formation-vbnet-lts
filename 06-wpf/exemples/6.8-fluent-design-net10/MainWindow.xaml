<!-- ============================================================================
     Section 6.8 : Thèmes et Fluent Design (.NET 10)
     Description : Démontre deux apports de .NET 10 :
                  · le thème Fluent via la propriété ThemeMode (réglée en
                    code-behind ; API expérimentale -> NoWarn WPF0001 dans le
                    .vbproj) ;
                  · la SYNTAXE ABRÉGÉE de Grid (.NET 10) : RowDefinitions et
                    ColumnDefinitions déclarés en chaîne, au lieu des blocs
                    <Grid.RowDefinitions> verbeux.
     Fichier source : 08-fluent-design-net10.md
============================================================================ -->
<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="6.8 — Fluent Design (.NET 10)" Height="300" Width="460"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <!-- Syntaxe abrégée .NET 10 : 3 lignes (Auto, *, 40), 2 colonnes (120, *) -->
    <Grid Margin="12" RowDefinitions="Auto, *, 40" ColumnDefinitions="120, *">

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontWeight="Bold" FontSize="15"
                   Text="Thème Fluent + syntaxe Grid abrégée" Margin="0,0,0,8" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Thème :" VerticalAlignment="Top" />
        <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBlock x:Name="lblTheme" Text="(thème appliqué…)" TextWrapping="Wrap" />
            <Button Content="Bouton (style Fluent)" Width="180" HorizontalAlignment="Left" Margin="0,8" />
            <CheckBox Content="Option Fluent" Margin="0,4" />
            <TextBox Text="Champ Fluent" Margin="0,4" Width="180" HorizontalAlignment="Left" />
        </StackPanel>

        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Foreground="Gray" VerticalAlignment="Center"
                   Text="ThemeMode = System : suit le clair/sombre de Windows." />
    </Grid>
</Window>
