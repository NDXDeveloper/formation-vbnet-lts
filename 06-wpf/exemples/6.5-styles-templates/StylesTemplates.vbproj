<!-- =========================================================================
  Section 6.5 : Styles, ressources, templates et triggers
  Description : Projet WPF VB.NET (.NET 10), structure du modele Visual Studio.
  Fichier source : 05-styles-templates.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>StylesTemplates</RootNamespace>
    <UseWPF>true</UseWPF>
  </PropertyGroup>

  <ItemGroup>
    <Import Include="System.Windows" />
    <Import Include="System.Windows.Controls" />
    <Import Include="System.Windows.Data" />
    <Import Include="System.Windows.Input" />
    <Import Include="System.Windows.Media" />
    <Import Include="System.Windows.Media.Animation" />
    <Import Include="System.Windows.Media.Imaging" />
    <Import Include="System.Windows.Shapes" />
  </ItemGroup>

</Project>
