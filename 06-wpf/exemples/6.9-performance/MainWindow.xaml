<!-- ============================================================================
     Section 6.9 : Performance WPF (virtualisation, binding, rendu)
     Description : Illustre les leviers de la section :
                  · VIRTUALISATION : une ListBox de 10 000 éléments, avec
                    VirtualizationMode=Recycling — seuls les éléments visibles
                    créent des conteneurs (l'interface reste fluide). La liste
                    reçoit une hauteur bornée (un des « tueurs de
                    virtualisation » est de la placer dans une hauteur infinie).
                  · le décodage d'image à la taille d'affichage
                    (DecodePixelWidth) est montré en commentaire (pas d'image
                    embarquée dans cet exemple).
     Fichier source : 09-performance.md
============================================================================ -->
<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="6.9 — Performance" Height="380" Width="460"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <DockPanel Margin="12">
        <TextBlock DockPanel.Dock="Top" x:Name="lblInfo" TextWrapping="Wrap" Margin="0,0,0,8" />

        <!-- Liste virtualisée : 10 000 éléments, conteneurs recyclés -->
        <ListBox x:Name="grandeListe"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Item" />

        <!-- Décodage d'image à la taille d'affichage (rappel de la section) :
        <Image>
            <Image.Source>
                <BitmapImage UriSource="photo.jpg" DecodePixelWidth="200" />
            </Image.Source>
        </Image>
        -->
    </DockPanel>
</Window>
