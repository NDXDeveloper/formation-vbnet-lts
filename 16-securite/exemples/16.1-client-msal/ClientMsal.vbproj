<!-- =========================================================================
  Section 16.1 : Authentification — client public (MSAL.NET)
  Description : Console VB.NET (.NET 10) illustrant l'acquisition de jeton d'accès
                via MSAL.NET (Microsoft.Identity.Client) : essai SILENCIEUX (cache)
                puis bascule INTERACTIVE si nécessaire. Le projet COMPILE ; il n'est
                pas exécuté ici car l'acquisition réelle exige une inscription
                d'application dans Microsoft Entra ID et un navigateur. Met en
                évidence un motif propre à VB : « Await » est interdit dans un bloc
                Catch (BC36943).
  Fichier source : 01-auth.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>ClientMsal</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Identity.Client" Version="4.66.2" />
  </ItemGroup>

</Project>
