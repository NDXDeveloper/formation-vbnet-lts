<!-- =========================================================================
  Section 17.9 : tester la PLOMBERIE de l'intégration IA
  Description : Tests xUnit déterministes utilisant le faux IChatClient. On ne teste
                JAMAIS une sortie de modèle réelle (non déterministe) : on vérifie que
                la question est acheminée, que la réponse revient, que le RAG récupère
                le bon passage et qu'il l'injecte bien dans le prompt.
  Fichier source : 09-consommer-ia.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>IntegrationIA.Tests</RootNamespace>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\IntegrationIA\IntegrationIA.vbproj" />
  </ItemGroup>

</Project>
