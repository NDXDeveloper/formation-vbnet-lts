<!-- =========================================================================
  Section 17.9 : Intégrer l'IA dans une application VB.NET (consommation)
  Description : Bibliothèque VB.NET (.NET 10). Consomme l'abstraction
                Microsoft.Extensions.AI (IChatClient) — pure consommation .NET, la
                zone de confort de VB. Aucune clé d'API : un FAUX client déterministe
                permet de tester la PLOMBERIE de l'intégration (la section rappelle
                qu'on ne peut pas asserter une sortie de modèle réelle). Inclut un RAG
                basique en mémoire (vectorisation simple + similarité cosinus).
  Fichier source : 09-consommer-ia.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>IntegrationIA</RootNamespace>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="9.7.0" />
  </ItemGroup>

</Project>
