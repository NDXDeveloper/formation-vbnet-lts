<!-- =========================================================================
  Section 1.3 : L'écosystème .NET — Structure d'une solution (solution mixte)
  Description : Interface Windows Forms (VB.NET) de la solution
                « MaSolution ». Cible net10.0-windows (Windows Forms dépend
                de Windows) avec UseWindowsForms, comme indiqué dans la
                section. Référence la logique métier VB, qui référence
                elle-même la brique C#.
  Fichier source : 03-ecosysteme-dotnet.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>MonApp.UI</RootNamespace>
    <StartupObject>Sub Main</StartupObject>
    <UseWindowsForms>true</UseWindowsForms>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

  <ItemGroup>
    <Import Include="System.Data" />
    <Import Include="System.Drawing" />
    <Import Include="System.Windows.Forms" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MonApp.Metier\MonApp.Metier.vbproj" />
  </ItemGroup>

</Project>
