<!-- =========================================================================
  Section 1.6.2 : La stratégie hybride VB.NET / C# en une page
  Description : Le projet VB.NET de la solution hybride. L'étape 2 du
                « Comment ça marche » de la section : le projet VB
                RÉFÉRENCE la bibliothèque C# (ProjectReference) — il ne
                reste qu'à appeler son API publique comme n'importe quel
                type .NET (voir Program.vb).
  Fichier source : 06.2-strategie-hybride.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>AppVB</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\ModerneLib\ModerneLib.csproj" />
  </ItemGroup>

</Project>
