<!-- =========================================================================
  Section 7.5 : Sérialisation
  Description : Console VB.NET (.NET 10). JSON (System.Text.Json, intégré) et
                XML (XmlSerializer + littéraux XML VB) ne demandent aucun
                paquet. CSV utilise CsvHelper (référence) ; TextFieldParser
                (intégré au runtime VB) est aussi démontré.
  Fichier source : 05-serialisation.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>Serialisation</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CsvHelper" Version="33.1.0" />
  </ItemGroup>

</Project>
