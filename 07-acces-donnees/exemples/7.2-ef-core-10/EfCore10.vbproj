<!-- =========================================================================
  Section 7.2 : Entity Framework Core 10
  Description : Console VB.NET (.NET 10) avec EF Core 10 sur SQLite (le cours
                utilise SQL Server/LocalDB ; SQLite évite tout serveur). Le
                schéma est créé par EnsureCreated, car la GÉNÉRATION de
                migrations EF Core est C# uniquement (cf. section 7.2) —
                EnsureCreated convient à une petite base locale.
  Fichier source : 02-ef-core-10.md
========================================================================== -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>EfCore10</RootNamespace>
    <TargetFramework>net10.0</TargetFramework>
    <OptionStrict>On</OptionStrict>
    <OptionExplicit>On</OptionExplicit>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="10.0.0" />
  </ItemGroup>

</Project>
